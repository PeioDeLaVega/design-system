@use "./common" as common;

:root {
  /* FONTS *******************************************************************/
  --font-family-sans-serif: #{common.$font-family-sans-serif};
  --font-family-serif: #{common.$font-family-serif};
  --font-family-base: #{common.$font-family-base};
  --font-family-publico-bold: #{common.$font-family-publico-bold};
  --font-family-publico: #{common.$font-family-publico};
  --font-size-base: 16;

  /* COLORS *******************************************************************/

  --color-white: #{common.$color-white};
  --color-black: #{common.$color-black};

  /* blue */
  --color-axa: #{common.$color-axa};
  --color-blue-1: #{common.$color-blue-1};
  --color-blue-2: #{common.$color-blue-2};
  --color-blue-3: #{common.$color-blue-3};
  --color-blue-200: #{common.$color-blue-200};
  --color-blue-800: #{common.$color-blue-800};
  --color-blue-400: #{common.$color-blue-400};
  --color-ocean-blue: #{common.$color-oceanBlue};
  --color-btn-light: #{common.$color-btn-light};
  --color-focus: #{common.$color-focus}; /* prefer use --color-blue-3*/
  --color-btn-tertiary-bg: #{common.$color-btn-tertiary-bg};
  --color-btn-tertiary-bg-darker: #{common.$color-btn-tertiary-bg-darker};
  --color-btn-tertiary-bg-lighter: #{common.$color-btn-tertiary-bg-lighter};

  /* red */
  --color-red: #{common.$color-red};
  --color-red-600: #{common.$color-red-600};
  --color-red-700: #{common.$color-red-700};
  --color-btn-error-text: #{common.$color-btn-error-text};
  --color-btn-error-bg: #{common.$color-btn-error-bg};
  --error-custom-border: #{common.$error-custom-border};
  --error-custom-bg: #{common.$error-custom-bg};

  /* orange */
  --color-alert-danger-color-border: #{common.$color-alertDanger-colorBorder};
  --color-alert-danger-bg-color: #{common.$color-alertDanger-bgColor};
  --color-btn-business: #{common.$color-btn-business};
  --color-btn-business-dark: #{common.$color-btn-business-dark};
  --color-btn-business-light: #{common.$color-btn-business-light};
  --color-orange-100: #{common.$color-orange-100};
  --color-orange-700: #{common.$color-orange-700};

  /* gray */
  --color-gray: #{common.$color-gray};
  --color-gray-1: #{common.$color-gray-1};
  --color-gray-32: #{common.$color-gray-32};
  --color-gray-200: #{common.$color-gray-200};
  --color-gray-300: #{common.$color-gray-300};
  --color-gray-400: #{common.$color-gray-400};
  --color-gray-500: #{common.$color-gray-500};
  --color-gray-700: #{common.$color-gray-700};
  --color-gray-900: #{common.$color-gray-900};
  --color-btn-disabled-text: #{common.$color-btn-disabled-text};
  --color-border: #{common.$color-border}; /* prefer use --color-gray-200*/

  /* green */
  --color-green-600: #{common.$color-green-600};

  /* SIZING *******************************************************************/

  --sizing-u0: #{common.$sizing-u0};
  --sizing-u05: #{common.$sizing-u05};
  --sizing-u1: #{common.$sizing-u1};
  --sizing-u2: #{common.$sizing-u2};
  --sizing-u3: #{common.$sizing-u3};
  --sizing-u4: #{common.$sizing-u4};
  --sizing-u5: #{common.$sizing-u5};
  --sizing-u6: #{common.$sizing-u6};
  --sizing-u7: #{common.$sizing-u7};
  --sizing-u8: #{common.$sizing-u8};
  --sizing-u9: #{common.$sizing-u9};
  --sizing-u10: #{common.$sizing-u10};

  /* SPACING *******************************************************************/

  --spacing-u05: #{common.$spacing-u05};
  --spacing-u0: #{common.$spacing-u0};
  --spacing-u1: #{common.$spacing-u1};
  --spacing-u2: #{common.$spacing-u2};
  --spacing-u3: #{common.$spacing-u3};
  --spacing-u4: #{common.$spacing-u4};
  --spacing-u5: #{common.$spacing-u5};
  --spacing-u6: #{common.$spacing-u6};
  --spacing-u7: #{common.$spacing-u7};
  --spacing-u8: #{common.$spacing-u8};
  --spacing-u9: #{common.$spacing-u9};
  --spacing-u10: #{common.$spacing-u10};
  --spacing-u11: #{common.$spacing-u11};
  --spacing-u12: #{common.$spacing-u12};
  --spacing-u13: #{common.$spacing-u13};
  --spacing-u14: #{common.$spacing-u14};
  --spacing-u15: #{common.$spacing-u15};
  --spacing-u16: #{common.$spacing-u16};
  --spacing-u17: #{common.$spacing-u17};
  --spacing-u18: #{common.$spacing-u18};
  --spacing-u19: #{common.$spacing-u19};
  --spacing-u20: #{common.$spacing-u20};

  /* SCREENS & BREAKPOINTS *******************************************************************/

  --screen-size-s: #{common.$screen-size-s};
  --screen-size-m: #{common.$screen-size-m};
  --screen-size-l: #{common.$screen-size-l};
  --screen-size-xl: #{common.$screen-size-xl};
  --screen-size-oldl: #{common.$screen-size-oldl};
  --screen-size-oldxl: #{common.$screen-size-oldxl};
  --breakpoint-xs: #{common.$breakpoint-xs};
  --breakpoint-sm: #{common.$breakpoint-sm};
  --breakpoint-md: #{common.$breakpoint-md};
  --breakpoint-lg: #{common.$breakpoint-lg};
  --breakpoint-xl: #{common.$breakpoint-xl};

  /* BORDERS *******************************************************************/

  --default-border-radius: #{common.$default-border-radius};
  --radius-8: #{common.$radius-8};
  --radius-12: #{common.$radius-12};
  --radius-32: #{common.$radius-32};
  --radius-100: #{common.$radius-100};

  /* ANIMATIONS *******************************************************************/

  --transition-duration: #{common.$transition-duration};
}
